# TradingView MCP Configuration Example

# API Keys
TRADINGVIEW_API_KEY=your_api_key_here
TRADINGVIEW_SECRET_KEY=your_secret_key_here

# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=8080

# Database Settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tradingview_mcp
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Alert Configuration
ALERT_EMAIL=alerts@example.com
ALERT_SMS=+1234567890
ALERT_WEBHOOK=https://your_webhook_url_here
